                                 .equ	NRWW_START_ADDR	= 0x3800
                                 .equ	NRWW_STOP_ADDR	= 0x3fff
                                 .equ	RWW_START_ADDR	= 0x0
                                 .equ	RWW_STOP_ADDR	= 0x37ff
                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 * Proyecto_1.asm
                                 *
                                 * Creado: 27-Feb-26
                                 * Autor : Juan Daniel Sandoval Rodriguez
                                 * Descripcion:
                                 *   - Reloj de 24 Horas con alarma y fecha
                                 *   - Se utilizan 4 botones, A0 es para los modos, A1 es para incrementar y A2 es para decrementar, A3 es el elegido para la alarma
                                 *   - 4 Displays con Multiplexado, ademas 2 leds, secundero y modo
                                 *   - El clock va igual a funcionar como el lab 3 por 1ms de momento.
                                 ****************************************/
                                 .include "M328PDEF.inc"
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 .dseg
                                 .org SRAM_START
000100                           ss: .byte 1
000101                           mm: .byte 1
000102                           hh: .byte 1
000103                           ticks1ms:	.byte 2		;Contador de ticks 1 ms
000105                           blink_dp:   .byte 1
000106                           mux_digit:  .byte 1
                                 
000107                           mode:       .byte 1		;Congifuracion ya de las cosas del reloj
000108                           edit_flag:  .byte 1
000109                           btn_prev:   .byte 1
00010a                           debounce_cnt: .byte 1
00010b                           mode_lock: .byte 1
00010c                           edit_digit: .byte 1
                                 
00010d                           dd: .byte 1	;Variable del dia
00010e                           mes: .byte 1 ;Variable del mes
                                 
00010f                           alarm_hh: .byte 1
000110                           alarm_mm: .byte 1
000111                           alarm_on: .byte 1
000112                           alarm_ringing: .byte 1
                                 
000113                           set_lock: .byte 1 ;Variable de si se esta editando el valor
000114                           inc_lock: .byte 1
000115                           sel_lock: .byte 1
                                 
                                 
                                 .cseg
                                 .org 0x0000
000000 c01c                          rjmp START
                                 
                                 .org 0x001C
00001c c06e                          rjmp ISR_T0_COMPA ;Direccion de disparo de las interrupciones del timer 0
                                 
                                 ;==================== STACK ====================
                                 START:
00001d ef0f                          ldi r16, LOW(RAMEND)
00001e bf0d                          out SPL, r16
00001f e008                          ldi r16, HIGH(RAMEND)
000020 bf0e                          out SPH, r16
                                 
                                 ;==================== SETUP ====================
                                 SETUP:
000021 2700                      	clr r16
000022 9300 0103                 	sts ticks1ms, r16
000024 9300 0104                 	sts ticks1ms+1, r16
                                 
                                 	;Limpiar los valores de la hora
000026 2700                          clr r16
000027 9300 0100                     sts ss, r16
                                 
000029 e202                          ldi r16, 34
00002a 9300 0101                     sts mm, r16
                                 
00002c e00c                          ldi r16, 12
00002d 9300 0102                     sts hh, r16
                                 
00002f e001                      	ldi r16, 1
000030 9300 010d                 	sts dd, r16
                                 
000032 e001                      	ldi r16, 1
000033 9300 010e                 	sts mes, r16
                                 
                                 
000035 9300 0105                 	sts blink_dp, r16
000037 9300 0106                 	sts mux_digit, r16
                                 
                                 
000039 9a3d                      	sbi DDRC, 5
00003a 9a45                      	sbi PORTC, 5
                                 
00003b 2700                          clr r16
00003c 9300 0107                     sts mode, r16
00003e 9300 0108                     sts edit_flag, r16
                                 
000040 e00f                          ldi r16, 0x0F
000041 9300 0109                     sts btn_prev, r16 ;pull-up
                                 
000043 2700                      	clr r16
000044 9300 010a                 	sts debounce_cnt, r16
                                 
000046 2700                      	clr r16
000047 9300 010b                 	sts mode_lock, r16
                                 
000049 2700                      	clr r16
00004a 9300 0113                 	sts set_lock, r16
                                 
00004c 2700                      	clr r16
00004d 9300 0114                 	sts inc_lock, r16
                                 
00004f 2700                      	clr r16
000050 9300 0115                 	sts sel_lock, r16
                                 
                                     ; Segmentos D2-D7 como salida
000052 ef0c                          ldi r16, 0b11111100
000053 b90a                          out DDRD, r16
                                 
                                     ; PB0 = D8 como salida
000054 e10f                          ldi r16, 0b00011111
000055 b904                          out DDRB, r16
                                 
                                     ; Todos los segmentos apagados al inicio
000056 ef0c                          ldi r16, 0b11111100
000057 b90b                          out PORTD, r16
                                 
                                     ; PB0 apagado y todos los digitos desactivados
000058 e10f                          ldi r16, 0b00011111
000059 b905                      	out PORTB, r16
                                 
                                 ;==================== BOTONES ====================
                                     ; A0 Modo, A1 Cambio, A2 Arriba, A3 Set
                                 
00005a 9838                          cbi DDRC, 0
00005b 9839                          cbi DDRC, 1
00005c 983a                          cbi DDRC, 2
00005d 983b                          cbi DDRC, 3
                                 
00005e 9a40                          sbi PORTC, 0
00005f 9a41                          sbi PORTC, 1
000060 9a42                          sbi PORTC, 2
000061 9a43                          sbi PORTC, 3
                                 
000062 9a50                      	sbi DDRD, 0      ; D0 como salida, El que muestra el modo
000063 9858                      	cbi PORTD, 0     ; LED apagado
                                 
                                 
                                 ; Timer0 CTC 1ms
000064 e000                          ldi r16, 0
000065 bd04                          out TCCR0A, r16
                                 
000066 e002                          ldi r16, (1<<WGM01)
000067 bd04                          out TCCR0A, r16
                                 
000068 ef0a                          ldi r16, 250
000069 bd07                          out OCR0A, r16
                                 
00006a 2700                          clr r16
00006b bd06                          out TCNT0, r16
                                 
00006c e002                          ldi r16, (1<<OCIE0A)
00006d 9300 006e                     sts TIMSK0, r16
                                 
00006f e003                          ldi r16, (1<<CS01)|(1<<CS00) ;Pre escaler de 64
000070 bd05                          out TCCR0B, r16
                                 
                                 ;==================== ALARM ====================
                                 
000071 e006                      	ldi r16,6
000072 9300 010f                 	sts alarm_hh,r16
                                 
000074 e10e                      	ldi r16,30
000075 9300 0110                 	sts alarm_mm,r16
                                 
000077 2700                      	clr r16
000078 9300 0111                 	sts alarm_on,r16
                                 
00007a 2700                      	clr r16
00007b 9300 0112                 	sts alarm_ringing, r16
                                 
00007d 9a3c                      	sbi DDRC, 4      ; A4 como salida
00007e 9844                      	cbi PORTC, 4     ; buzzer apagado
                                 
00007f 9478                          sei
                                 
                                 ;==================== MAIN ====================
                                 MAIN_LOOP:
000080 d079                          rcall MUX_UPDATE
000081 d187                          rcall HANDLE_BTNS
000082 d2b0                          rcall BUZZER_UPDATE
                                 
                                     ; LED EDIT en D0
000083 9100 0108                     lds r16, edit_flag
000085 2300                          tst r16
000086 f011                          breq LED_OFF
                                 
                                 LED_ON:
000087 9a58                          sbi PORTD, 0
000088 c001                          rjmp LED_DONE
                                 
                                 LED_OFF:
000089 9858                          cbi PORTD, 0
                                 
                                 LED_DONE:
                                 
00008a cff5                          rjmp MAIN_LOOP
                                 
                                 ;==================== SUB ====================
                                 
                                 ISR_T0_COMPA:
00008b 930f                      	push r16
00008c 931f                      	push r17
00008d 932f                      	push r18
00008e b70f                      	in	 r16, SREG
00008f 930f                      	push r16
                                 
000090 9100 0103                     lds r16, ticks1ms ;Byte bajo 16
000092 9110 0104                 	lds r17, ticks1ms+1 ;Byte alto 16
000094 9503                          inc r16
000095 f409                          brne T_SAVE
000096 9513                      	inc r17
                                 
                                 T_SAVE:
000097 9300 0103                     sts  ticks1ms, r16
000099 9310 0104                     sts  ticks1ms+1, r17
                                 
                                 ;==================== DEBOUNCE ====================
                                 
00009b 9120 010a                     lds r18, debounce_cnt
00009d 2322                          tst r18
00009e f019                          breq DB_DONE
00009f 952a                          dec r18
0000a0 9320 010a                     sts debounce_cnt, r18
                                 
                                 DB_DONE:
                                 
                                     ; comparar con 1000
0000a2 3e08                          cpi  r16, LOW(1000)
0000a3 f5e1                          brne GO_T_END
0000a4 3013                          cpi  r17, HIGH(1000)
0000a5 f5d1                          brne GO_T_END
                                 
                                     ; si llego a 1000 ms: reset ticks a 0
0000a6 2700                          clr  r16
0000a7 2711                          clr  r17
0000a8 9300 0103                     sts  ticks1ms, r16
0000aa 9310 0104                     sts  ticks1ms+1, r17
                                 
                                 
                                 
                                 ;============ ======== RELOJ ====================
0000ac 9100 0100                     lds  r16, ss
0000ae 9503                          inc  r16
0000af 330c                          cpi  r16, 60
0000b0 f168                          brlo SAVE_SS
                                 
                                     ; ss llego a 60
0000b1 2700                          clr  r16
0000b2 9300 0100                     sts  ss, r16
                                 
0000b4 9100 0101                     lds  r16, mm
0000b6 9503                          inc  r16
0000b7 330c                          cpi  r16, 60
0000b8 f110                          brlo SAVE_MM
                                 
                                     ; mm llego a 60
0000b9 2700                          clr  r16
0000ba 9300 0101                     sts  mm, r16
                                 
0000bc 9100 0102                     lds  r16, hh
0000be 9503                          inc  r16
0000bf 3108                          cpi  r16, 24
0000c0 f0b8                          brlo SAVE_HH
                                 
                                     ; hh llego a 24
0000c1 2700                          clr  r16
0000c2 9300 0102                     sts  hh, r16
                                 
                                     ; avanzar dia
0000c4 9100 010d                     lds  r16, dd
0000c6 9503                          inc  r16
0000c7 3200                          cpi  r16, 32
0000c8 f060                          brlo SAVE_DD
                                 
                                     ; dd llego a 32 -> reiniciar a 1 y subir mes
0000c9 e001                          ldi  r16, 1
0000ca 9300 010d                     sts  dd, r16
                                 
0000cc 9100 010e                     lds  r16, mes
0000ce 9503                          inc  r16
0000cf 300d                          cpi  r16, 13
0000d0 f008                          brlo SAVE_MES
                                 
                                     ; mes llego a 13 -> volver a 1
0000d1 e001                          ldi  r16, 1
                                 
                                 SAVE_MES:
0000d2 9300 010e                     sts  mes, r16
0000d4 c00c                          rjmp ALARM_COMPARE
                                 
                                 SAVE_DD:
0000d5 9300 010d                     sts  dd, r16
0000d7 c009                          rjmp ALARM_COMPARE
                                 
                                 SAVE_HH:
0000d8 9300 0102                     sts  hh, r16
0000da c006                          rjmp ALARM_COMPARE
                                 
                                 SAVE_MM:
0000db 9300 0101                     sts  mm, r16
0000dd c003                          rjmp ALARM_COMPARE
                                 
                                 SAVE_SS:
0000de 9300 0100                     sts  ss, r16
                                 
                                 
                                 GO_T_END:
0000e0 c013                      	rjmp T_END
                                 
                                 ALARM_COMPARE:
                                     ;==================== COMPARAR ALARMA ====================
                                 
0000e1 9100 0102                     lds r16, hh
0000e3 9110 010f                     lds r17, alarm_hh
0000e5 1701                          cp  r16, r17
0000e6 f469                          brne ALARM_CHECK_END
                                 
0000e7 9100 0101                     lds r16, mm
0000e9 9110 0110                     lds r17, alarm_mm
0000eb 1701                          cp  r16, r17
0000ec f439                          brne ALARM_CHECK_END
                                 
0000ed 9100 0100                     lds r16, ss
0000ef 2300                          tst r16
0000f0 f419                          brne ALARM_CHECK_END
                                 
0000f1 e001                          ldi r16, 1
0000f2 9300 0112                     sts alarm_ringing, r16
                                 
                                 ALARM_CHECK_END:
                                 
                                 T_END:
0000f4 910f                          pop  r16
0000f5 bf0f                          out  SREG, r16
0000f6 912f                      	pop	 r18
0000f7 911f                          pop  r17
0000f8 910f                          pop  r16
0000f9 9518                          reti
                                 
                                 ;==================== MULTIPLEXADO ====================
                                 MUX_UPDATE:
0000fa 930f                          push r16
0000fb 931f                          push r17
0000fc 932f                          push r18
0000fd 933f                          push r19
                                 
                                     ; digitos apagados
0000fe 9a29                          sbi PORTB, 1
0000ff 9a2a                          sbi PORTB, 2
000100 9a2b                          sbi PORTB, 3
000101 9a2c                          sbi PORTB, 4
                                 
                                     ; DP apagado por defecto
000102 9a45                          sbi PORTC, 5     ; HIGH apaga dp
                                 
                                 	;Parpadeo de display
000103 9100 0108                     lds r16, edit_flag
000105 2300                          tst r16
000106 c00a                          rjmp MUX_CONTINUE_NORMAL
                                 
000107 9110 0103                     lds r17, ticks1ms
000109 9120 0104                     lds r18, ticks1ms+1
                                 
00010b 3023                          cpi r18, HIGH(800)
00010c f020                          brlo MUX_CONTINUE_NORMAL
00010d f411                          brne MUX_BLANK
                                 
00010e 321c                          cpi r17, LOW(300)
00010f f008                          brlo MUX_CONTINUE_NORMAL
                                 
                                 MUX_BLANK:
000110 c0e6                          rjmp MUX_NEXT_ONLY
                                 
                                 MUX_CONTINUE_NORMAL:
                                 
                                     ; Ver que digito toca
000111 9120 0106                     lds r18, mux_digit
                                 
000113 9130 0107                 	lds r19, mode
                                 
000115 3030                      	cpi r19, 0
000116 f019                      	breq GO_MODE_CLOCK
000117 3031                      	cpi r19, 1
000118 f011                      	breq GO_MODE_DATE
000119 c03e                      	rjmp MUX_MODE_ALARM
                                 
                                 	GO_MODE_CLOCK:
00011a c001                          rjmp MUX_MODE_CLOCK
                                 
                                 	GO_MODE_DATE:
00011b c00a                          rjmp MUX_MODE_DATE
                                 
                                 ;==================== CLOCK ====================
                                 
                                 	MUX_MODE_CLOCK:
00011c 3020                      	cpi r18, 0
00011d f029                      	breq GO_DIG1_CLOCK
00011e 3021                      	cpi r18, 1
00011f f021                      	breq GO_DIG2_CLOCK
000120 3022                      	cpi r18, 2
000121 f019                      	breq GO_DIG3_CLOCK
000122 c06e                      	rjmp MUX_DIG4_CLOCK
                                 
                                 	GO_DIG1_CLOCK:
000123 c03e                          rjmp MUX_DIG1_CLOCK
                                 	GO_DIG2_CLOCK:
000124 c04a                          rjmp MUX_DIG2_CLOCK
                                 	GO_DIG3_CLOCK:
000125 c05e                          rjmp MUX_DIG3_CLOCK
                                 
                                 ;==================== FECHA ====================
                                 
                                 	MUX_MODE_DATE:
000126 3020                          cpi r18, 0
000127 f029                          breq GO_DIG1_DATE
000128 3021                          cpi r18, 1
000129 f021                          breq GO_DIG2_DATE
00012a 3022                          cpi r18, 2
00012b f019                          breq GO_DIG3_DATE
00012c c092                          rjmp MUX_DIG4_DATE
                                 
                                 	GO_DIG1_DATE:
00012d c06d                          rjmp MUX_DIG1_DATE
                                 
                                 	GO_DIG2_DATE:
00012e c079                          rjmp MUX_DIG2_DATE
                                 
                                 	GO_DIG3_DATE:
00012f c082                          rjmp MUX_DIG3_DATE
                                 
                                 CHECK_DAY_LIMIT:
                                 
000130 930f                          push r16
000131 931f                          push r17
                                 
000132 9100 010e                     lds r16,mes
                                 
000134 3002                          cpi r16,2
000135 f0c1                          breq FEB_CHECK
                                 
000136 3004                          cpi r16,4
000137 f071                          breq M30_CHECK
000138 3006                          cpi r16,6
000139 f061                          breq M30_CHECK
00013a 3009                          cpi r16,9
00013b f051                          breq M30_CHECK
00013c 300b                          cpi r16,11
00013d f041                          breq M30_CHECK
                                 
                                 ; ====== meses de 31 ======
                                 
                                 M31_CHECK:
00013e 9110 010d                     lds r17,dd
000140 3210                          cpi r17,32
000141 f098                          brlo DAY_OK
000142 e11f                          ldi r17,31
000143 9310 010d                     sts dd,r17
000145 c00f                          rjmp DAY_OK
                                 
                                 ; ====== meses de 30 ======
                                 
                                 M30_CHECK:
000146 9110 010d                     lds r17,dd
000148 311f                          cpi r17,31
000149 f058                          brlo DAY_OK
00014a e11e                          ldi r17,30
00014b 9310 010d                     sts dd,r17
00014d c007                          rjmp DAY_OK
                                 
                                 ; ====== febrero ======
                                 
                                 FEB_CHECK:
00014e 9110 010d                     lds r17,dd
000150 311d                          cpi r17,29
000151 f018                          brlo DAY_OK
000152 e11c                          ldi r17,28
000153 9310 010d                     sts dd,r17
                                 
                                 DAY_OK:
000155 911f                          pop r17
000156 910f                          pop r16
000157 9508                          ret
                                 
                                 ;==================== ALARM ====================
                                 
                                 	MUX_MODE_ALARM:
000158 3020                          cpi r18, 0
000159 f029                          breq GO_DIG1_ALARM
00015a 3021                          cpi r18, 1
00015b f021                          breq GO_DIG2_ALARM
00015c 3022                          cpi r18, 2
00015d f019                          breq GO_DIG3_ALARM
00015e c08e                          rjmp MUX_DIG4_ALARM
                                 
                                 	GO_DIG1_ALARM:
00015f c069                          rjmp MUX_DIG1_ALARM
                                 
                                 	GO_DIG2_ALARM:
000160 c075                          rjmp MUX_DIG2_ALARM
                                 
                                 	GO_DIG3_ALARM:
000161 c07e                          rjmp MUX_DIG3_ALARM
                                 
                                 ;--------------------------------------------------------
                                 ; DIG1 = decena de hora
                                 MUX_DIG1_CLOCK:
000162 9100 0102                     lds r16, hh
000164 2711                          clr r17              ; r17 = decenas
                                 MUX_HH_TENS_LOOP:
000165 300a                          cpi r16, 10
000166 f018                          brlo MUX_HH_TENS_DONE
000167 500a                          subi r16, 10
000168 9513                          inc r17
000169 cffb                          rjmp MUX_HH_TENS_LOOP
                                 MUX_HH_TENS_DONE:
00016a 2f01                          mov r16, r17
00016b d1eb                          rcall HEX_TO_PAT
00016c d1d6                          rcall OUT_SEGMENTS
00016d 9829                          cbi PORTB, 1
00016e c088                          rjmp MUX_NEXT
                                 
                                 ;--------------------------------------------------------
                                 ; DIG2 = unidad de hora
                                 MUX_DIG2_CLOCK:
00016f 9100 0102                     lds r16, hh
                                 MUX_HH_UNITS_LOOP:
000171 300a                          cpi r16, 10
000172 f010                          brlo MUX_HH_UNITS_DONE
000173 500a                          subi r16, 10
000174 cffc                          rjmp MUX_HH_UNITS_LOOP
                                 MUX_HH_UNITS_DONE:
000175 d1e1                          rcall HEX_TO_PAT
000176 d1cc                          rcall OUT_SEGMENTS
                                 
                                     ; dp segun mitad de segundo
000177 9110 0103                     lds r17, ticks1ms
000179 9120 0104                     lds r18, ticks1ms+1
                                 
                                     ; comparar ticks1ms con 500 (0x01F4)
00017b 3021                          cpi r18, HIGH(500)
00017c f020                          brlo MUX_DIG2_DP_ON
00017d f421                          brne MUX_DIG2_DP_DONE
                                 
00017e 3f14                          cpi r17, LOW(500)
00017f f008                          brlo MUX_DIG2_DP_ON
000180 c001                          rjmp MUX_DIG2_DP_DONE
                                 
                                 MUX_DIG2_DP_ON:
000181 9845                          cbi PORTC, 5              ; LOW = encender dp
                                 
                                 MUX_DIG2_DP_DONE:
000182 982a                          cbi PORTB, 2
000183 c073                          rjmp MUX_NEXT
                                 
                                 ;--------------------------------------------------------
                                 ; DIG3 = decena de minuto
                                 MUX_DIG3_CLOCK:
000184 9100 0101                     lds r16, mm
000186 2711                          clr r17
                                 MUX_MM_TENS_LOOP:
000187 300a                          cpi r16, 10
000188 f018                          brlo MUX_MM_TENS_DONE
000189 500a                          subi r16, 10
00018a 9513                          inc r17
00018b cffb                          rjmp MUX_MM_TENS_LOOP
                                 MUX_MM_TENS_DONE:
00018c 2f01                          mov r16, r17
00018d d1c9                          rcall HEX_TO_PAT
00018e d1b4                          rcall OUT_SEGMENTS
00018f 982b                          cbi PORTB, 3
000190 c066                          rjmp MUX_NEXT
                                 
                                 ;--------------------------------------------------------
                                 ; DIG4 = unidad de minuto
                                 MUX_DIG4_CLOCK:
000191 9100 0101                     lds r16, mm
                                 MUX_MM_UNITS_LOOP:
000193 300a                          cpi r16, 10
000194 f010                          brlo MUX_MM_UNITS_DONE
000195 500a                          subi r16, 10
000196 cffc                          rjmp MUX_MM_UNITS_LOOP
                                 MUX_MM_UNITS_DONE:
000197 d1bf                          rcall HEX_TO_PAT
000198 d1aa                          rcall OUT_SEGMENTS
000199 982c                          cbi PORTB, 4
00019a c05c                      	rjmp MUX_NEXT
                                 
                                 ;--------------------------------------------------------
                                 ; DIG1 = decena de dia
                                 MUX_DIG1_DATE:
00019b 9100 010d                     lds r16, dd
00019d 2711                          clr r17
                                 MUX_DD_TENS_LOOP:
00019e 300a                          cpi r16, 10
00019f f018                          brlo MUX_DD_TENS_DONE
0001a0 500a                          subi r16, 10
0001a1 9513                          inc r17
0001a2 cffb                          rjmp MUX_DD_TENS_LOOP
                                 MUX_DD_TENS_DONE:
0001a3 2f01                          mov r16, r17
0001a4 d1b2                          rcall HEX_TO_PAT
0001a5 d19d                          rcall OUT_SEGMENTS
0001a6 9829                          cbi PORTB, 1
0001a7 c04f                          rjmp MUX_NEXT
                                 
                                 ;--------------------------------------------------------
                                 ; DIG2 = unidad de dia
                                 MUX_DIG2_DATE:
0001a8 9100 010d                     lds r16, dd
                                 MUX_DD_UNITS_LOOP:
0001aa 300a                          cpi r16, 10
0001ab f010                          brlo MUX_DD_UNITS_DONE
0001ac 500a                          subi r16, 10
0001ad cffc                          rjmp MUX_DD_UNITS_LOOP
                                 MUX_DD_UNITS_DONE:
0001ae d1a8                          rcall HEX_TO_PAT
0001af d193                          rcall OUT_SEGMENTS
0001b0 982a                          cbi PORTB, 2
0001b1 c045                          rjmp MUX_NEXT
                                 
                                 ;--------------------------------------------------------
                                 ; DIG3 = decena de mes
                                 MUX_DIG3_DATE:
0001b2 9100 010e                     lds r16, mes
0001b4 2711                          clr r17
                                 MUX_MES_TENS_LOOP:
0001b5 300a                          cpi r16, 10
0001b6 f018                          brlo MUX_MES_TENS_DONE
0001b7 500a                          subi r16, 10
0001b8 9513                          inc r17
0001b9 cffb                          rjmp MUX_MES_TENS_LOOP
                                 MUX_MES_TENS_DONE:
0001ba 2f01                          mov r16, r17
0001bb d19b                          rcall HEX_TO_PAT
0001bc d186                          rcall OUT_SEGMENTS
0001bd 982b                          cbi PORTB, 3
0001be c038                          rjmp MUX_NEXT
                                 
                                 ;--------------------------------------------------------
                                 ; DIG4 = unidad de mes
                                 MUX_DIG4_DATE:
0001bf 9100 010e                     lds r16, mes
                                 MUX_MES_UNITS_LOOP:
0001c1 300a                          cpi r16, 10
0001c2 f010                          brlo MUX_MES_UNITS_DONE
0001c3 500a                          subi r16, 10
0001c4 cffc                          rjmp MUX_MES_UNITS_LOOP
                                 MUX_MES_UNITS_DONE:
0001c5 d191                          rcall HEX_TO_PAT
0001c6 d17c                          rcall OUT_SEGMENTS
0001c7 982c                          cbi PORTB, 4
0001c8 c02e                          rjmp MUX_NEXT
                                 
                                 ;--------------------------------------------------------
                                 MUX_DIG1_ALARM:
0001c9 9100 010f                     lds r16,alarm_hh
0001cb 2711                          clr r17
                                 
                                 AL_HH_TENS_LOOP:
0001cc 300a                          cpi r16,10
0001cd f018                          brlo AL_HH_TENS_DONE
0001ce 500a                          subi r16,10
0001cf 9513                          inc r17
0001d0 cffb                          rjmp AL_HH_TENS_LOOP
                                 
                                 AL_HH_TENS_DONE:
0001d1 2f01                          mov r16,r17
0001d2 d184                          rcall HEX_TO_PAT
0001d3 d16f                          rcall OUT_SEGMENTS
0001d4 9829                          cbi PORTB,1
0001d5 c021                          rjmp MUX_NEXT
                                 
                                 MUX_DIG2_ALARM:
0001d6 9100 010f                     lds r16,alarm_hh
                                 
                                 AL_HH_UNITS_LOOP:
0001d8 300a                          cpi r16,10
0001d9 f010                          brlo AL_HH_UNITS_DONE
0001da 500a                          subi r16,10
0001db cffc                          rjmp AL_HH_UNITS_LOOP
                                 
                                 AL_HH_UNITS_DONE:
0001dc d17a                          rcall HEX_TO_PAT
0001dd d165                          rcall OUT_SEGMENTS
0001de 982a                          cbi PORTB,2
0001df c017                          rjmp MUX_NEXT
                                 
                                 MUX_DIG3_ALARM:
0001e0 9100 0110                     lds r16,alarm_mm
0001e2 2711                          clr r17
                                 
                                 AL_MM_TENS_LOOP:
0001e3 300a                          cpi r16,10
0001e4 f018                          brlo AL_MM_TENS_DONE
0001e5 500a                          subi r16,10
0001e6 9513                          inc r17
0001e7 cffb                          rjmp AL_MM_TENS_LOOP
                                 
                                 AL_MM_TENS_DONE:
0001e8 2f01                          mov r16,r17
0001e9 d16d                          rcall HEX_TO_PAT
0001ea d158                          rcall OUT_SEGMENTS
0001eb 982b                          cbi PORTB,3
0001ec c00a                          rjmp MUX_NEXT
                                 
                                 MUX_DIG4_ALARM:
0001ed 9100 0110                     lds r16,alarm_mm
                                 
                                 AL_MM_UNITS_LOOP:
0001ef 300a                          cpi r16,10
0001f0 f010                          brlo AL_MM_UNITS_DONE
0001f1 500a                          subi r16,10
0001f2 cffc                          rjmp AL_MM_UNITS_LOOP
                                 
                                 AL_MM_UNITS_DONE:
0001f3 d163                          rcall HEX_TO_PAT
0001f4 d14e                          rcall OUT_SEGMENTS
0001f5 982c                          cbi PORTB,4
0001f6 c000                          rjmp MUX_NEXT
                                 
                                 MUX_NEXT_ONLY:
                                 MUX_NEXT:
0001f7 9100 0106                     lds r16, mux_digit
0001f9 9503                          inc r16
0001fa 3004                          cpi r16, 4
0001fb f008                          brlo MUX_SAVE
0001fc 2700                          clr r16
                                 MUX_SAVE:
0001fd 9300 0106                     sts mux_digit, r16
                                 
0001ff 913f                          pop r19
000200 912f                          pop r18
000201 911f                          pop r17
000202 910f                          pop r16
000203 9508                          ret
                                 
                                 ;==================== END MULTIPLEX ====================
                                 
                                 READ_BTNS:
000204 b106                          in   r16, PINC
000205 700f                          andi r16, 0x0F      ; solo PC0-PC3
000206 9500                          com  r16            ; invertir
000207 700f                          andi r16, 0x0F
000208 9508                          ret
                                 
                                 HANDLE_BTNS:
000209 930f                          push r16
00020a 931f                          push r17
00020b 932f                          push r18
                                 
                                     ; leer botones actuales
00020c dff7                          rcall READ_BTNS
00020d 2f10                          mov  r17, r16
                                 
                                 	; si cualquier boton esta presionado, apagar alarma
00020e 2311                          tst  r17
00020f f019                          breq NO_ALARM_STOP
                                 
000210 2700                          clr  r16
000211 9300 0112                     sts  alarm_ringing, r16
                                 
                                 NO_ALARM_STOP:
                                 
                                     ;==================== MODE ====================
                                     ; si MODE no esta presionado -> liberar lock
000213 ff10                          sbrs r17, 0
000214 c001                          rjmp HB_MODE_RELEASED
000215 c004                          rjmp HB_MODE_CHECK
                                 
                                 HB_MODE_RELEASED:
000216 2700                          clr  r16
000217 9300 010b                     sts  mode_lock, r16
000219 c01b                          rjmp HB_SET_START
                                 
                                 HB_MODE_CHECK:
                                     ; si debounce activo, no hacer nada con MODE
00021a 9100 010a                     lds  r16, debounce_cnt
00021c 2300                          tst  r16
00021d f4b9                          brne HB_SET_START
                                 
                                     ; si ya estaba bloqueado, no hacer nada con MODE
00021e 9100 010b                     lds  r16, mode_lock
000220 2300                          tst  r16
000221 f499                          brne HB_SET_START
                                 
                                     ; MODE solo funciona si NO estoy editando
000222 9100 0108                     lds  r16, edit_flag
000224 2300                          tst  r16
000225 f479                          brne HB_SET_START
                                 
                                     ; nueva pulsacion valida de MODE
000226 9100 0107                     lds  r16, mode
000228 9503                          inc  r16
000229 3003                      	cpi  r16, 3
00022a f008                      	brlo GO_HB_MODE_OK
00022b 2700                      	clr  r16
                                 
                                 GO_HB_MODE_OK:
00022c c000                          rjmp HB_MODE_OK
                                 
                                 HB_MODE_OK:
00022d 9300 0107                     sts mode, r16
                                 
                                     ; bloquear hasta liberar
00022f e001                          ldi  r16, 1
000230 9300 010b                     sts  mode_lock, r16
                                 
                                     ; debounce corto
000232 e104                          ldi  r16, 20
000233 9300 010a                     sts  debounce_cnt, r16
                                 
                                     ;==================== SET ====================
                                 HB_SET_START:
                                     ; si SET no esta presionado -> liberar lock
000235 ff13                          sbrs r17, 3
000236 c001                          rjmp HB_SET_RELEASED
000237 c004                          rjmp HB_SET_CHECK
                                 
                                 HB_SET_RELEASED:
000238 2700                          clr  r16
000239 9300 0113                     sts  set_lock, r16
00023b c01b                          rjmp HB_SEL_START
                                 
                                 HB_SET_CHECK:
                                     ; debounce activo?
00023c 9100 010a                     lds  r16, debounce_cnt
00023e 2300                          tst  r16
00023f f4b1                          brne GO_HB_END
                                 
                                     ; ya estaba bloqueado?
000240 9100 0113                     lds  r16, set_lock
000242 2300                          tst  r16
000243 f499                          brne HB_SEL_START
                                 
                                     ; toggle edit_flag
000244 9100 0108                     lds  r16, edit_flag
000246 e021                          ldi  r18, 1
000247 2702                          eor  r16, r18
000248 9300 0108                     sts  edit_flag, r16
                                 
                                     ; si entro a edicion -> empezar en digito 0
00024a 2300                          tst  r16
00024b f019                          breq HB_SET_LOCK
                                 
00024c 2722                          clr  r18
00024d 9320 010c                     sts  edit_digit, r18
                                 
                                 HB_SET_LOCK:
00024f e001                          ldi  r16, 1
000250 9300 0113                     sts  set_lock, r16
                                 
000252 e104                          ldi  r16, 20
000253 9300 010a                     sts  debounce_cnt, r16
                                 
000255 c001                          rjmp HB_SEL_START
                                 
                                 GO_HB_END:
000256 c0d8                          rjmp HB_END
                                 
                                 ;==================== SELECT DIGIT (A1) ====================
                                 HB_SEL_START:
                                     ; si A1 no esta presionado -> liberar lock
000257 ff11                          sbrs r17, 1
000258 c001                          rjmp HB_SEL_RELEASED
000259 c004                          rjmp HB_SEL_CHECK
                                 
                                 HB_SEL_RELEASED:
00025a 2700                          clr  r16
00025b 9300 0115                     sts  sel_lock, r16
00025d c01a                          rjmp HB_INC_START
                                 
                                 HB_SEL_CHECK:
                                     ; solo funciona si edit_flag = 1
00025e 9100 0108                     lds  r16, edit_flag
000260 2300                          tst  r16
000261 f0b1                          breq HB_INC_START
                                 
                                     ; debounce activo?
000262 9100 010a                     lds  r16, debounce_cnt
000264 2300                          tst  r16
000265 f491                          brne HB_INC_START
                                 
                                     ; ya estaba bloqueado?
000266 9100 0115                     lds  r16, sel_lock
000268 2300                          tst  r16
000269 f471                          brne HB_INC_START
                                 
                                     ; avanzar edit_digit: 0->1->2->3->0
00026a 9100 010c                     lds  r16, edit_digit
00026c 9503                          inc  r16
00026d 3004                          cpi  r16, 4
00026e f008                          brlo HB_SEL_OK
00026f 2700                          clr  r16
                                 
                                 HB_SEL_OK:
000270 9300 010c                     sts  edit_digit, r16
                                 
                                     ; bloquear hasta liberar
000272 e001                          ldi  r16, 1
000273 9300 0115                     sts  sel_lock, r16
                                 
                                     ; debounce corto
000275 e104                          ldi  r16, 20
000276 9300 010a                     sts  debounce_cnt, r16
                                 
                                 ;==================== INCREMENT DIGIT (A2) ====================
                                 
                                 HB_INC_START:
                                 
                                     ; si A2 no esta presionado -> liberar lock
000278 ff12                          sbrs r17,2
000279 c001                          rjmp HB_INC_RELEASED
00027a c004                          rjmp HB_INC_CHECK
                                 
                                 HB_INC_RELEASED:
00027b 2700                          clr  r16
00027c 9300 0114                     sts  inc_lock,r16
00027e c0b0                          rjmp HB_END
                                 
                                 HB_INC_CHECK:
                                 
00027f 9100 0108                     lds  r16,edit_flag
000281 2300                          tst  r16
000282 f299                          breq GO_HB_END
                                 
000283 9100 010a                     lds  r16,debounce_cnt
000285 2300                          tst  r16
000286 f679                          brne GO_HB_END
                                 
000287 9100 0114                     lds  r16,inc_lock
000289 2300                          tst  r16
00028a f659                          brne GO_HB_END
                                 
00028b 9120 0107                     lds r18,mode
00028d 3020                          cpi r18,0
00028e f019                          breq GO_EDIT_CLOCK
                                 
00028f 3021                          cpi r18,1
000290 f011                          breq GO_EDIT_DATE
                                 
000291 c017                          rjmp EDIT_ALARM
                                 
                                 GO_EDIT_CLOCK:
000292 c001                          rjmp EDIT_CLOCK
                                 
                                 GO_EDIT_DATE:
000293 c009                          rjmp EDIT_DATE
                                 
                                 EDIT_CLOCK:
                                 
000294 9120 010c                     lds r18,edit_digit
                                 
000296 3020                          cpi r18,0
000297 f0e9                          breq GO_INC_HH_TENS
000298 3021                          cpi r18,1
000299 f0e1                          breq GO_INC_HH_UNITS
00029a 3022                          cpi r18,2
00029b f0d9                          breq GO_INC_MM_TENS
00029c c037                          rjmp INC_MM_UNITS
                                 
                                 EDIT_DATE:
00029d 9120 010c                 	lds r18,edit_digit
                                 
00029f 3020                          cpi r18,0
0002a0 f029                          breq GO_INC_DD_TENS
0002a1 3021                          cpi r18,1
0002a2 f021                          breq GO_INC_DD_UNITS
0002a3 3022                          cpi r18,2
0002a4 f019                          breq GO_INC_MES_TENS
0002a5 c054                          rjmp INC_MES_UNITS
                                 
                                 GO_INC_DD_TENS:
0002a6 c035                          rjmp INC_DD_TENS
                                 
                                 GO_INC_DD_UNITS:
0002a7 c03e                          rjmp INC_DD_UNITS
                                 
                                 GO_INC_MES_TENS:
0002a8 c047                          rjmp INC_MES_TENS
                                 
                                 EDIT_ALARM:
                                 
0002a9 9120 010c                     lds r18,edit_digit
                                 
0002ab 3020                          cpi r18,0
0002ac f029                          breq GO_INC_AL_HH_TENS
0002ad 3021                          cpi r18,1
0002ae f021                          breq GO_INC_AL_HH_UNITS
0002af 3022                          cpi r18,2
0002b0 f019                          breq GO_INC_AL_MM_TENS
0002b1 c06d                          rjmp INC_AL_MM_UNITS
                                 
                                 GO_INC_AL_HH_TENS:
0002b2 c051                          rjmp INC_AL_HH_TENS
                                 
                                 GO_INC_AL_HH_UNITS:
0002b3 c059                          rjmp INC_AL_HH_UNITS
                                 
                                 GO_INC_AL_MM_TENS:
0002b4 c061                          rjmp INC_AL_MM_TENS
                                 
                                 GO_INC_HH_TENS:
0002b5 c002                          rjmp INC_HH_TENS
                                 
                                 GO_INC_HH_UNITS:
0002b6 c00b                          rjmp INC_HH_UNITS
                                 
                                 GO_INC_MM_TENS:
0002b7 c013                          rjmp INC_MM_TENS
                                 
                                 INC_HH_TENS:
0002b8 9100 0102                     lds r16,hh
0002ba 500a                          subi r16,10
0002bb f412                          brpl HH_TENS_OK
0002bc e104                          ldi r16,20
0002bd c001                          rjmp SAVE_HH_TENS
                                 
                                 HH_TENS_OK:
0002be 5f06                          subi r16,-10
                                 
                                 SAVE_HH_TENS:
0002bf 9300 0102                     sts hh,r16
0002c1 c066                          rjmp INC_DONE
                                 
                                 INC_HH_UNITS:
0002c2 9100 0102                     lds r16,hh
0002c4 9503                          inc r16
0002c5 3108                          cpi r16,24
0002c6 f008                          brlo SAVE_HH_UNITS
0002c7 2700                          clr r16
                                 
                                 SAVE_HH_UNITS:
0002c8 9300 0102                     sts hh,r16
0002ca c05d                          rjmp INC_DONE
                                 
                                 INC_MM_TENS:
0002cb 9100 0101                     lds r16,mm
0002cd 5f06                          subi r16,-10
0002ce 330c                          cpi r16,60
0002cf f008                          brlo SAVE_MM_TENS
0002d0 2700                          clr r16
                                 
                                 SAVE_MM_TENS:
0002d1 9300 0101                     sts mm,r16
0002d3 c054                          rjmp INC_DONE
                                 
                                 INC_MM_UNITS:
0002d4 9100 0101                     lds r16,mm
0002d6 9503                          inc r16
0002d7 330c                          cpi r16,60
0002d8 f008                          brlo SAVE_MM_UNITS
0002d9 2700                          clr r16
                                 
                                 SAVE_MM_UNITS:
0002da 9300 0101                     sts mm,r16
                                 
                                 INC_DD_TENS:
0002dc 9100 010d                     lds r16,dd
0002de 5f06                          subi r16,-10
0002df 3200                          cpi r16,32
0002e0 f008                          brlo SAVE_DD_TENS
0002e1 e001                          ldi r16,1
                                 
                                 SAVE_DD_TENS:
0002e2 9300 010d                     sts dd,r16
0002e4 de4b                      	rcall CHECK_DAY_LIMIT
0002e5 c042                          rjmp INC_DONE
                                 
                                 INC_DD_UNITS:
0002e6 9100 010d                     lds r16,dd
0002e8 9503                          inc r16
0002e9 3200                          cpi r16,32
0002ea f008                          brlo SAVE_DD_UNITS
0002eb e001                          ldi r16,1
                                 
                                 SAVE_DD_UNITS:
0002ec 9300 010d                     sts dd,r16
0002ee de41                      	rcall CHECK_DAY_LIMIT
0002ef c038                          rjmp INC_DONE
                                 
                                 INC_MES_TENS:
0002f0 9100 010e                     lds r16,mes
0002f2 5f06                          subi r16,-10
0002f3 300d                          cpi r16,13
0002f4 f008                          brlo SAVE_MES_TENS
0002f5 e001                          ldi r16,1
                                 
                                 SAVE_MES_TENS:
0002f6 9300 010e                     sts mes,r16
0002f8 de37                      	rcall CHECK_DAY_LIMIT
0002f9 c02e                          rjmp INC_DONE
                                 
                                 INC_MES_UNITS:
0002fa 9100 010e                     lds r16,mes
0002fc 9503                          inc r16
0002fd 300d                          cpi r16,13
0002fe f008                          brlo SAVE_MES_UNITS
0002ff e001                          ldi r16,1
                                 
                                 SAVE_MES_UNITS:
000300 9300 010e                     sts mes,r16
000302 de2d                      	rcall CHECK_DAY_LIMIT
000303 c024                          rjmp INC_DONE
                                 
                                 INC_AL_HH_TENS:
000304 9100 010f                     lds r16,alarm_hh
000306 5f06                          subi r16,-10
000307 3108                          cpi r16,24
000308 f008                          brlo SAVE_AL_HH_TENS
000309 2700                          clr r16
                                 
                                 SAVE_AL_HH_TENS:
00030a 9300 010f                     sts alarm_hh,r16
00030c c01b                          rjmp INC_DONE
                                 
                                 INC_AL_HH_UNITS:
00030d 9100 010f                     lds r16,alarm_hh
00030f 9503                          inc r16
000310 3108                          cpi r16,24
000311 f008                          brlo SAVE_AL_HH_UNITS
000312 2700                          clr r16
                                 
                                 SAVE_AL_HH_UNITS:
000313 9300 010f                     sts alarm_hh,r16
000315 c012                          rjmp INC_DONE
                                 
                                 INC_AL_MM_TENS:
000316 9100 0110                     lds r16,alarm_mm
000318 5f06                          subi r16,-10
000319 330c                          cpi r16,60
00031a f008                          brlo SAVE_AL_MM_TENS
00031b 2700                          clr r16
                                 
                                 SAVE_AL_MM_TENS:
00031c 9300 0110                     sts alarm_mm,r16
00031e c009                          rjmp INC_DONE
                                 
                                 INC_AL_MM_UNITS:
00031f 9100 0110                     lds r16,alarm_mm
000321 9503                          inc r16
000322 330c                          cpi r16,60
000323 f008                          brlo SAVE_AL_MM_UNITS
000324 2700                          clr r16
                                 
                                 SAVE_AL_MM_UNITS:
000325 9300 0110                     sts alarm_mm,r16
000327 c000                          rjmp INC_DONE
                                 
                                 INC_DONE:
                                 
                                     ; activar lock
000328 e001                          ldi r16,1
000329 9300 0114                     sts inc_lock,r16
                                 
                                     ; debounce
00032b e104                          ldi r16,20
00032c 9300 010a                     sts debounce_cnt,r16
                                 
00032e c000                          rjmp HB_END
                                 
                                 HB_END:
00032f 912f                          pop  r18
000330 911f                          pop  r17
000331 910f                          pop  r16
000332 9508                          ret
                                 
                                 BUZZER_UPDATE:
000333 930f                          push r16
000334 931f                          push r17
                                 
000335 9100 0112                     lds r16, alarm_ringing
000337 2300                          tst r16
000338 f031                          breq BUZZER_OFF
                                 
                                     ; usar ticks para hacer PWM
000339 9110 0103                     lds r17, ticks1ms
